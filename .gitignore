# ============================================================
# ROOT .gitignore — CareerAI Project
# ============================================================

# ── Node / npm ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── Python virtual environment ───────────────────────────────
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pdb

# ── Environment / secrets (KHÔNG đẩy lên git) ───────────────
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.backup

# ── Build / dist output ──────────────────────────────────────
/build
/dist
frontend/build/
frontend/dist/

# ── User-uploaded files (dữ liệu nhạy cảm) ──────────────────
backend/static/uploads/*
!backend/static/uploads/.gitkeep

# ── Scratch / temp files ─────────────────────────────────────
backend/scratch/
*.log
*.tmp
*.bak
*.swp
*.swo

# ── Python debug / migration helpers ────────────────────────
backend/check_schema.py
backend/create_otp_table.py
backend/get_schema.py
backend/inspect_db.py
backend/db.js
backend/server.js

# ── OS / editor noise ────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.user

# ── Testing ──────────────────────────────────────────────────
/coverage
.pnp
.pnp.js
