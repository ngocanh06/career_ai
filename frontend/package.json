{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "html2canvas": "npm:html2canvas-pro@^2.2.4",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "postinstall": "node -e \"const fs = require('fs'); const path = require('path'); const dirs = [path.join('node_modules','html2canvas','dist'), path.join('node_modules','html2pdf.js','node_modules','html2canvas','dist')]; dirs.forEach(dist => { if (fs.existsSync(dist)) { ['html2canvas-pro.js','html2canvas-pro.js.map','html2canvas-pro.min.js'].forEach(f => { const src = path.join(dist, f); const dest = path.join(dist, f.replace('-pro','')); if (fs.existsSync(src)) fs.copyFileSync(src, dest); }); } });\"",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
